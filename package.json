{
  "name": "dbridge-mcp",
  "version": "0.7.0",
  "description": "MCP server that lets AI agents query a SQL database in natural language, safely and read-only.",
  "type": "module",
  "bin": {
    "dbridge-mcp": "dist/index.js"
  },
  "main": "dist/index.js",
  "files": [
    "dist",
    "!dist/seed.js",
    "!dist/db.js"
  ],
  "engines": {
    "node": ">=22.5.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/ugurcl/dbridge-mcp.git"
  },
  "homepage": "https://github.com/ugurcl/dbridge-mcp#readme",
  "bugs": {
    "url": "https://github.com/ugurcl/dbridge-mcp/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "test": "tsc && node --test \"tests/**/*.test.js\"",
    "start": "node dist/index.js",
    "seed": "tsc && node dist/seed.js",
    "inspect": "tsc && npx @modelcontextprotocol/inspector node dist/index.js demo.db",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "sqlite",
    "database",
    "sql",
    "ai",
    "llm"
  ],
  "author": "ugurcl",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "mysql2": "^3.22.5",
    "pg": "^8.22.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@electric-sql/pglite": "^0.5.3",
    "@types/node": "^22.10.0",
    "@types/pg": "^8.20.0",
    "typescript": "^5.7.0"
  }
}
